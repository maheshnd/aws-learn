    {
      "id": "01-cloud-computing-shared-responsibility-model",
      "topicNumber": 1,
      "topicSlug": "01-cloud-computing",
      "sectionId": "shared-responsibility-model",
      "sectionTitle": "🔐 Shared Responsibility Model",
      "type": "concept",
      "text": "> Core rule: AWS secures the cloud (the building). You secure IN the cloud (your apartment). Most breaches happen on YOUR side. Responsibility Changes by Service Type Where Breaches Actually Happen ---"
    },
    {
