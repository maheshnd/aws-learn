  "entries": [
    {
      "id": "01-cloud-computing-the-story-why-cloud-was-invented",
      "topicNumber": 1,
      "topicSlug": "01-cloud-computing",
      "sectionId": "the-story-why-cloud-was-invented",
      "sectionTitle": "🧒 The Story — Why Cloud Was Invented",
      "type": "story",
      "text": "Imagine it's 2004. You want to build a website like Facebook. What you had to do before cloud: Amazon had this exact problem internally. Every team waited months for servers. In ~2003, they built an internal platform: any team could get a server in minutes, pay per hour, return when done. In 2006 they realized: every company has this problem. They opened it to the public → AWS was born. - March 2006 → S3 launched ($0.15/GB/month) - August 2006 → EC2 launched (beta) - 2010 → Amazon.com itself mig"
    },
    {
      "id": "01-cloud-computing-what-cloud-computing-actually-is",
      "topicNumber": 1,
      "topicSlug": "01-cloud-computing",
      "sectionId": "what-cloud-computing-actually-is",
      "sectionTitle": "📐 What Cloud Computing Actually Is",
      "type": "concept",
      "text": "> Simple version: Renting computing power over the internet, paying only for what you use, scaling up or down in seconds. Official NIST definition (broken down): | Term | Plain English | |------|--------------| | On-demand | Get it when you need it. No waiting, no approval. | | Network access | Access over the internet from anywhere | | Shared pool | AWS's millions of servers, you borrow some | | Rapidly provisioned | Server in 90 seconds. Delete in 30 seconds. | | Minimal effort | You don't man"
    },
    {
      "id": "01-cloud-computing-5-the-5-characteristics-of-cloud-nist-must-know",
      "topicNumber": 1,
      "topicSlug": "01-cloud-computing",
      "sectionId": "5-the-5-characteristics-of-cloud-nist-must-know",
      "sectionTitle": "5️⃣ The 5 Characteristics of Cloud (NIST — Must Know)",
      "type": "concept",
      "text": "> If a service is missing even one of these → it is NOT truly cloud. Use this to challenge any vendor's \"cloud\" claim. 1. On-Demand Self-Service 2. Broad Network Access 3. Resource Pooling (Multi-tenancy) 4. Rapid Elasticity 5. Measured Service (Pay-as-you-go) ---"
    },
    {
      "id": "01-cloud-computing-service-models-iaas-paas-saas",
      "topicNumber": 1,
      "topicSlug": "01-cloud-computing",
      "sectionId": "service-models-iaas-paas-saas",
      "sectionTitle": "🏗️ Service Models — IaaS, PaaS, SaaS",
      "type": "concept",
      "text": "> Pizza analogy: Made at home = you do everything. Restaurant dine-in = they cook, you eat there. Delivery = they do everything. IaaS — Infrastructure as a Service PaaS — Platform as a Service SaaS — Software as a Service ---"
    },
